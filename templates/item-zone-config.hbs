<form class="persistent-zones-item-config">
  <div class="persistent-zones-item-config__shell">
    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--primary">
      <details class="persistent-zones-item-config__section-toggle" open>
        <summary class="persistent-zones-item-config__section-summary">
          <span class="persistent-zones-item-config__section-title">{{localize "PERSISTENT_ZONES.UI.Sections.Activation"}}</span>
          <span class="persistent-zones-item-config__section-meta">
            {{#if state.enabled}}
              {{localize "PERSISTENT_ZONES.UI.Common.Enabled"}}
            {{else}}
              {{localize "PERSISTENT_ZONES.UI.Common.Disabled"}}
            {{/if}}
          </span>
        </summary>

        <div class="persistent-zones-item-config__section-body">
          <div class="form-group">
            <label>{{localize "PERSISTENT_ZONES.UI.Fields.Enabled"}}</label>
            <input type="checkbox" name="enabled" {{#if state.enabled}}checked{{/if}}>
          </div>
        </div>
      </details>
    </section>

    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--profiles">
      <details class="persistent-zones-item-config__section-toggle persistent-zones-item-config__section-toggle--profiles" data-action="toggle-profile-section" {{#if profilesExpanded}}open{{/if}}>
        <summary class="persistent-zones-item-config__section-summary">
          <span class="persistent-zones-item-config__section-title">{{localize "PERSISTENT_ZONES.UI.Sections.Profiles"}}</span>
          <span class="persistent-zones-item-config__section-meta">
            {{#if selectedProfileContext.profileLabel}}
              {{selectedProfileContext.profileLabel}}
            {{else}}
              {{localize "PERSISTENT_ZONES.UI.NoneOption"}}
            {{/if}}
          </span>
          <span class="persistent-zones-item-config__pill">{{profileListContext.summaryText}}</span>
        </summary>

        <div class="persistent-zones-item-config__section-body">
          <div class="persistent-zones-item-config__profile-row">
            <div class="form-group form-group--stacked form-group--compact">
              <label>{{localize "PERSISTENT_ZONES.UI.Fields.ProfileFilter"}}</label>
              <input type="text" name="profileFilter" value="{{profileFilter}}" placeholder="{{localize "PERSISTENT_ZONES.UI.Fields.ProfileFilter"}}" dir="ltr" inputmode="text" autocapitalize="off" autocomplete="off" spellcheck="false">
            </div>

            <div class="persistent-zones-item-config__profile-summary">
              <span class="persistent-zones-item-config__pill persistent-zones-item-config__pill--soft">{{selectedProfileContext.compatibilityLabel}}</span>
            </div>
          </div>

          <div class="form-group form-group--stacked form-group--compact">
            <label>{{localize "PERSISTENT_ZONES.UI.Fields.Profile"}}</label>
            <select name="selectedProfileId" data-action="select-profile">
              {{#each profileOptions as |option|}}
                <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
              {{/each}}
            </select>
          </div>

          {{#if profileListContext.hasFilter}}
            {{#unless profileListContext.hasMatches}}
              <p class="hint">{{localize "PERSISTENT_ZONES.UI.ProfileListNoMatches"}}</p>
            {{/unless}}
          {{/if}}

          {{#if selectedProfileContext.hasSelection}}
            <div class="persistent-zones-item-config__meta persistent-zones-item-config__meta--profiles">
              <div>
                <strong>{{localize "PERSISTENT_ZONES.UI.Fields.ProfileScope"}}:</strong>
                <span>{{selectedProfileContext.profileScopeLabel}}</span>
              </div>
              <div>
                <strong>{{localize "PERSISTENT_ZONES.UI.Fields.ProfileBaseType"}}:</strong>
                <span>{{selectedProfileContext.profileBaseTypeLabel}}</span>
              </div>
              <div>
                <strong>{{localize "PERSISTENT_ZONES.UI.Fields.ProfileTemplateType"}}:</strong>
                <span>{{selectedProfileContext.profileTemplateTypeLabel}}</span>
              </div>
              <div>
                <strong>{{localize "PERSISTENT_ZONES.UI.Fields.ProfileCompatibility"}}:</strong>
                <span>{{selectedProfileContext.compatibilityLabel}}</span>
              </div>
            </div>

            {{#if selectedProfileContext.compatibilityMessage}}
              <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}:</strong> {{selectedProfileContext.compatibilityMessage}}</p>
            {{/if}}
          {{else}}
            <p class="hint">{{localize "PERSISTENT_ZONES.UI.Help.ProfileSection"}}</p>
          {{/if}}

          <div class="persistent-zones-item-config__inline-actions persistent-zones-item-config__inline-actions--compact persistent-zones-item-config__profile-actions-grid persistent-zones-item-config__profile-actions-grid--primary">
            <button type="button" class="button" data-action="apply-profile" {{#unless selectedProfileContext.canApply}}disabled{{/unless}}>
              <i class="fas fa-folder-open"></i>
              <span>{{localize "PERSISTENT_ZONES.UI.Actions.ApplyProfile"}}</span>
            </button>
            <button type="button" class="button" data-action="duplicate-profile" {{#unless selectedProfileContext.canDuplicate}}disabled{{/unless}}>
              <i class="fas fa-copy"></i>
              <span>{{localize "PERSISTENT_ZONES.UI.Actions.DuplicateProfile"}}</span>
            </button>
            <button type="button" class="button" data-action="rename-profile" {{#unless selectedProfileContext.canRename}}disabled{{/unless}}>
              <i class="fas fa-pen"></i>
              <span>{{localize "PERSISTENT_ZONES.UI.Actions.RenameProfile"}}</span>
            </button>
            <button type="button" class="button" data-action="delete-profile" {{#unless selectedProfileContext.canDelete}}disabled{{/unless}}>
              <i class="fas fa-trash"></i>
              <span>{{localize "PERSISTENT_ZONES.UI.Actions.DeleteProfile"}}</span>
            </button>
          </div>

          <div class="persistent-zones-item-config__profile-save-row">
            <div class="form-group form-group--stacked form-group--compact">
              <label>{{localize "PERSISTENT_ZONES.UI.Fields.ProfileName"}}</label>
              <input type="text" name="profileName" value="{{profileNameDraft}}" placeholder="{{suggestedProfileName}}">
            </div>

            <button type="button" class="button persistent-zones-item-config__button--accent" data-action="save-profile" {{#unless canSaveProfile}}disabled{{/unless}}>
              <i class="fas fa-bookmark"></i>
              <span>{{localize "PERSISTENT_ZONES.UI.Actions.SaveProfile"}}</span>
            </button>
          </div>

          <p class="hint">{{localize "PERSISTENT_ZONES.UI.Help.ProfileSaveHint"}}</p>

          <div class="persistent-zones-item-config__inline-actions persistent-zones-item-config__inline-actions--compact persistent-zones-item-config__profile-actions-grid persistent-zones-item-config__profile-actions-grid--secondary">
            <button type="button" class="button" data-action="export-profiles">
              <i class="fas fa-file-export"></i>
              <span>{{localize "PERSISTENT_ZONES.UI.Actions.ExportProfiles"}}</span>
            </button>
            <button type="button" class="button" data-action="import-profiles">
              <i class="fas fa-file-import"></i>
              <span>{{localize "PERSISTENT_ZONES.UI.Actions.ImportProfiles"}}</span>
            </button>
          </div>

          <input type="file" accept=".json,application/json" data-action="import-profile-file" hidden>
        </div>
      </details>
    </section>

    <section class="persistent-zones-item-config__card">
      <details class="persistent-zones-item-config__section-toggle" open>
        <summary class="persistent-zones-item-config__section-summary">
          <span class="persistent-zones-item-config__section-title">{{localize "PERSISTENT_ZONES.UI.Sections.TemplateContext"}}</span>
          <span class="persistent-zones-item-config__section-meta">{{templateContextSummaryText}}</span>
        </summary>

        <div class="persistent-zones-item-config__section-body">
          <div class="persistent-zones-item-config__meta">
            <div>
              <strong>{{localize "PERSISTENT_ZONES.UI.Fields.DetectedTemplateType"}}:</strong>
              <span>
                {{#if templateTypeContext.detectedTemplateTypeLabel}}
                  {{templateTypeContext.detectedTemplateTypeLabel}}
                {{else}}
                  {{localize "PERSISTENT_ZONES.UI.NoneOption"}}
                {{/if}}
              </span>
            </div>
            <div>
              <strong>{{localize "PERSISTENT_ZONES.UI.Fields.DetectedTemplateSource"}}:</strong>
              <span>{{templateTypeContext.detectedTemplateSourceLabel}}</span>
            </div>
            <div>
              <strong>{{localize "PERSISTENT_ZONES.UI.Fields.EffectiveTemplateType"}}:</strong>
              <span>{{templateTypeContext.effectiveTemplateTypeLabel}}</span>
            </div>
          </div>

          {{#if templateTypeContext.warningReason}}
            <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}:</strong> {{templateTypeContext.warningReason}}</p>
          {{/if}}
        </div>
      </details>
    </section>

    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--primary">
      <details class="persistent-zones-item-config__section-toggle" open>
        <summary class="persistent-zones-item-config__section-summary">
          <span class="persistent-zones-item-config__section-title">{{localize "PERSISTENT_ZONES.UI.Sections.TypeVariant"}}</span>
          <span class="persistent-zones-item-config__section-meta">{{typeVariantSummaryText}}</span>
        </summary>

        <div class="persistent-zones-item-config__section-body">
          <div class="form-group form-group--stacked">
            <label>{{localize "PERSISTENT_ZONES.UI.Fields.BaseType"}}</label>
            <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--four">
              {{#each baseTypeOptions as |option|}}
                <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                  <input type="radio" name="baseType" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                  <span>{{option.label}}</span>
                </label>
              {{/each}}
            </div>
          </div>

          {{#if selectionContext.compatibleBaseTypeLabels}}
            <p class="hint">
              <strong>{{localize "PERSISTENT_ZONES.UI.Compatibility.CompatibleBaseTypes"}}:</strong>
              {{selectionContext.compatibleBaseTypeLabels}}
            </p>
          {{/if}}
          {{#if selectionContext.baseTypeWarningReason}}
            <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}:</strong> {{selectionContext.baseTypeWarningReason}}</p>
          {{/if}}

          {{#if showVariantSelect}}
            <div class="form-group form-group--stacked">
              <label>{{localize "PERSISTENT_ZONES.UI.Fields.SelectedVariant"}}</label>
              <div class="persistent-zones-item-config__choice-group">
                {{#each variantOptions as |option|}}
                  <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                    <input type="radio" name="selectedVariant" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                    <span>{{option.label}}</span>
                  </label>
                {{/each}}
              </div>
            </div>

            {{#if selectedVariantLabel}}
              <p class="hint">
                <strong>{{localize "PERSISTENT_ZONES.UI.Fields.SelectedVariant"}}:</strong>
                {{selectedVariantLabel}}
              </p>
            {{/if}}
            {{#if selectionContext.compatibleVariantLabels}}
              <p class="hint">
                <strong>{{localize "PERSISTENT_ZONES.UI.Compatibility.CompatibleVariants"}}:</strong>
                {{selectionContext.compatibleVariantLabels}}
              </p>
            {{/if}}
            {{#if selectionContext.variantWarningReason}}
              <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}:</strong> {{selectionContext.variantWarningReason}}</p>
            {{/if}}
          {{/if}}
        </div>
      </details>
    </section>

    {{#if showGeometrySection}}
      <section class="persistent-zones-item-config__card">
        <details class="persistent-zones-item-config__section-toggle" open>
          <summary class="persistent-zones-item-config__section-summary">
            <span class="persistent-zones-item-config__section-title">{{localize "PERSISTENT_ZONES.UI.Sections.DerivedGeometry"}}</span>
            <span class="persistent-zones-item-config__section-meta">{{geometrySummaryText}}</span>
          </summary>

          <div class="persistent-zones-item-config__section-body">
            {{#if showWallThickness}}
              <div class="form-group">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.WallThickness"}}</label>
                <input type="text" name="wallThickness" value="{{state.wallThickness}}" inputmode="decimal" placeholder="1.0">
              </div>
            {{/if}}

            {{#if showSideThickness}}
              <div class="form-group">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.SideThickness"}}</label>
                <input type="text" name="sideThickness" value="{{state.sideThickness}}" inputmode="decimal" placeholder="3.0">
              </div>
            {{/if}}
          </div>
        </details>
      </section>
    {{/if}}

    <section class="persistent-zones-item-config__card">
      <details class="persistent-zones-item-config__section-toggle" open>
        <summary class="persistent-zones-item-config__section-summary">
          <span class="persistent-zones-item-config__section-title">{{localize "PERSISTENT_ZONES.UI.Sections.Behaviors"}}</span>
          <span class="persistent-zones-item-config__section-meta">{{behaviorSummaryText}}</span>
        </summary>

        <div class="persistent-zones-item-config__section-body">
          {{#if showGlobalTriggers}}
            {{#each globalTriggerSections as |triggerSection|}}
              <fieldset class="persistent-zones-item-config__part-section">
                <legend>{{triggerSection.label}}</legend>

                <div class="form-group form-group--stacked">
                  <label>{{localize "PERSISTENT_ZONES.UI.Fields.TriggerMode"}}</label>
                  <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--three">
                    {{#each triggerSection.modeOptions as |option|}}
                      <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                        <input type="radio" name="{{triggerSection.modeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                        <span>{{option.label}}</span>
                      </label>
                    {{/each}}
                  </div>
                </div>

                {{#if triggerSection.showMovementMode}}
                  <div class="form-group form-group--stacked">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.MovementMode"}}</label>
                    <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--three">
                      {{#each triggerSection.movementModeOptions as |option|}}
                        <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                          <input type="radio" name="{{triggerSection.movementModeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                          <span>{{option.label}}</span>
                        </label>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}

                {{#if triggerSection.showStepMode}}
                  <div class="form-group form-group--stacked">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.StepMode"}}</label>
                    <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--two">
                      {{#each triggerSection.stepModeOptions as |option|}}
                        <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                          <input type="radio" name="{{triggerSection.stepModeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                          <span>{{option.label}}</span>
                        </label>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}

                {{#if triggerSection.showCellStep}}
                  <div class="form-group">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.CellStep"}}</label>
                    <input type="number" name="{{triggerSection.cellStepFieldName}}" value="{{triggerSection.state.cellStep}}" min="1" step="1">
                  </div>
                {{/if}}

                {{#if triggerSection.showDistanceStep}}
                  <div class="form-group">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.DistanceStep"}}</label>
                    <input type="text" name="{{triggerSection.distanceStepFieldName}}" value="{{triggerSection.state.distanceStep}}" inputmode="decimal" placeholder="5.0">
                  </div>
                {{/if}}

                {{#if triggerSection.showSimpleFields}}
                  <div class="form-group">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.DamageFormula"}}</label>
                    <input type="text" name="{{triggerSection.damageFormulaFieldName}}" value="{{triggerSection.state.damageFormula}}" placeholder="2d6">
                  </div>

                  <div class="form-group">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.DamageType"}}</label>
                    <select name="{{triggerSection.damageTypeFieldName}}">
                      {{#each triggerSection.damageTypeOptions as |option|}}
                        <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                      {{/each}}
                    </select>
                  </div>

                  <div class="form-group">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveAbility"}}</label>
                    <select name="{{triggerSection.saveAbilityFieldName}}" data-rerender="true">
                      {{#each triggerSection.abilityOptions as |option|}}
                        <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                      {{/each}}
                    </select>
                  </div>

                  {{#if triggerSection.showSaveDcMode}}
                    <div class="form-group form-group--stacked">
                      <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveDcMode"}}</label>
                      <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--two">
                        {{#each triggerSection.saveDcModeOptions as |option|}}
                          <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                            <input type="radio" name="{{triggerSection.saveDcModeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                            <span>{{option.label}}</span>
                          </label>
                        {{/each}}
                      </div>
                    </div>
                  {{/if}}

                  {{#if triggerSection.showManualSaveDc}}
                    <div class="form-group">
                      <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveDc"}}</label>
                      <input type="number" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}" min="1" step="1">
                    </div>
                  {{else}}
                    <input type="hidden" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}">
                  {{/if}}
                {{else}}
                  <input type="hidden" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}">
                {{/if}}

                {{#if triggerSection.showActivityField}}
                  <div class="form-group">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.Activity"}}</label>
                    <select name="{{triggerSection.activityFieldName}}">
                      {{#each triggerSection.activityField.options as |option|}}
                        <option value="{{option.value}}" {{#if option.selected}}selected{{/if}} {{#if option.disabled}}disabled{{/if}}>{{option.label}}</option>
                      {{/each}}
                    </select>
                  </div>

                  <p class="hint">{{triggerSection.activityField.helpText}}</p>

                  {{#if triggerSection.activityField.noCompatibleActivitiesMessage}}
                    <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.ActivityCompatibility.Incompatible"}}:</strong> {{triggerSection.activityField.noCompatibleActivitiesMessage}}</p>
                  {{/if}}

                  {{#if triggerSection.activityField.selectedActivityMessage}}
                    <p class="hint"><strong>{{triggerSection.activityField.selectedActivityStatusLabel}}:</strong> {{triggerSection.activityField.selectedActivityMessage}}</p>
                  {{/if}}
                {{/if}}
              </fieldset>
            {{/each}}
          {{/if}}

          {{#if showCompositePartSections}}
            {{#each partSections as |part|}}
              <section class="persistent-zones-item-config__part-block">
                <h3>{{part.label}}</h3>

                {{#each part.triggerSections as |triggerSection|}}
                  <fieldset class="persistent-zones-item-config__part-section">
                    <legend>{{triggerSection.label}}</legend>

                    <div class="form-group form-group--stacked">
                      <label>{{localize "PERSISTENT_ZONES.UI.Fields.TriggerMode"}}</label>
                      <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--three">
                        {{#each triggerSection.modeOptions as |option|}}
                          <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                            <input type="radio" name="{{triggerSection.modeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                            <span>{{option.label}}</span>
                          </label>
                        {{/each}}
                      </div>
                    </div>

                    {{#if triggerSection.showMovementMode}}
                      <div class="form-group form-group--stacked">
                        <label>{{localize "PERSISTENT_ZONES.UI.Fields.MovementMode"}}</label>
                        <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--three">
                          {{#each triggerSection.movementModeOptions as |option|}}
                            <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                              <input type="radio" name="{{triggerSection.movementModeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                              <span>{{option.label}}</span>
                            </label>
                          {{/each}}
                        </div>
                      </div>
                    {{/if}}

                    {{#if triggerSection.showStepMode}}
                      <div class="form-group form-group--stacked">
                        <label>{{localize "PERSISTENT_ZONES.UI.Fields.StepMode"}}</label>
                        <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--two">
                          {{#each triggerSection.stepModeOptions as |option|}}
                            <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                              <input type="radio" name="{{triggerSection.stepModeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                              <span>{{option.label}}</span>
                            </label>
                          {{/each}}
                        </div>
                      </div>
                    {{/if}}

                    {{#if triggerSection.showCellStep}}
                      <div class="form-group">
                        <label>{{localize "PERSISTENT_ZONES.UI.Fields.CellStep"}}</label>
                        <input type="number" name="{{triggerSection.cellStepFieldName}}" value="{{triggerSection.state.cellStep}}" min="1" step="1">
                      </div>
                    {{/if}}

                    {{#if triggerSection.showDistanceStep}}
                      <div class="form-group">
                        <label>{{localize "PERSISTENT_ZONES.UI.Fields.DistanceStep"}}</label>
                        <input type="text" name="{{triggerSection.distanceStepFieldName}}" value="{{triggerSection.state.distanceStep}}" inputmode="decimal" placeholder="5.0">
                      </div>
                    {{/if}}

                    {{#if triggerSection.showSimpleFields}}
                      <div class="form-group">
                        <label>{{localize "PERSISTENT_ZONES.UI.Fields.DamageFormula"}}</label>
                        <input type="text" name="{{triggerSection.damageFormulaFieldName}}" value="{{triggerSection.state.damageFormula}}" placeholder="2d6">
                      </div>

                      <div class="form-group">
                        <label>{{localize "PERSISTENT_ZONES.UI.Fields.DamageType"}}</label>
                        <select name="{{triggerSection.damageTypeFieldName}}">
                          {{#each triggerSection.damageTypeOptions as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </select>
                      </div>

                      <div class="form-group">
                        <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveAbility"}}</label>
                        <select name="{{triggerSection.saveAbilityFieldName}}" data-rerender="true">
                          {{#each triggerSection.abilityOptions as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </select>
                      </div>

                      {{#if triggerSection.showSaveDcMode}}
                        <div class="form-group form-group--stacked">
                          <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveDcMode"}}</label>
                          <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--two">
                            {{#each triggerSection.saveDcModeOptions as |option|}}
                              <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                                <input type="radio" name="{{triggerSection.saveDcModeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                                <span>{{option.label}}</span>
                              </label>
                            {{/each}}
                          </div>
                        </div>
                      {{/if}}

                      {{#if triggerSection.showManualSaveDc}}
                        <div class="form-group">
                          <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveDc"}}</label>
                          <input type="number" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}" min="1" step="1">
                        </div>
                      {{else}}
                        <input type="hidden" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}">
                      {{/if}}
                    {{else}}
                      <input type="hidden" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}">
                    {{/if}}

                    {{#if triggerSection.showActivityField}}
                      <div class="form-group">
                        <label>{{localize "PERSISTENT_ZONES.UI.Fields.Activity"}}</label>
                        <select name="{{triggerSection.activityFieldName}}">
                          {{#each triggerSection.activityField.options as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}} {{#if option.disabled}}disabled{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </select>
                      </div>

                      <p class="hint">{{triggerSection.activityField.helpText}}</p>

                      {{#if triggerSection.activityField.noCompatibleActivitiesMessage}}
                        <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.ActivityCompatibility.Incompatible"}}:</strong> {{triggerSection.activityField.noCompatibleActivitiesMessage}}</p>
                      {{/if}}

                      {{#if triggerSection.activityField.selectedActivityMessage}}
                        <p class="hint"><strong>{{triggerSection.activityField.selectedActivityStatusLabel}}:</strong> {{triggerSection.activityField.selectedActivityMessage}}</p>
                      {{/if}}
                    {{/if}}
                  </fieldset>
                {{/each}}
              </section>
            {{/each}}
          {{/if}}
        </div>
      </details>
    </section>

    <section class="persistent-zones-item-config__card">
      <details class="persistent-zones-item-config__section-toggle">
        <summary class="persistent-zones-item-config__section-summary">
          <span class="persistent-zones-item-config__section-title">{{localize "PERSISTENT_ZONES.UI.Sections.LinksTerrain"}}</span>
          <span class="persistent-zones-item-config__section-meta">{{linksTerrainContext.summaryText}}</span>
        </summary>

        <div class="persistent-zones-item-config__section-body">
          <div class="form-group form-group--stacked">
            <label>{{localize "PERSISTENT_ZONES.UI.Fields.TargetFilter"}}</label>
            <div class="persistent-zones-item-config__choice-group">
              {{#each linksTerrainContext.targetFilterOptions as |option|}}
                <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                  <input type="radio" name="targetFilter" value="{{option.value}}" {{#if option.selected}}checked{{/if}}>
                  <span>{{option.label}}</span>
                </label>
              {{/each}}
            </div>
          </div>

          <div class="form-group">
            <label>{{localize "PERSISTENT_ZONES.UI.Fields.DifficultTerrain"}}</label>
            <input type="checkbox" name="difficultTerrainEnabled" {{#if state.difficultTerrainEnabled}}checked{{/if}}>
          </div>

          <div class="form-group">
            <label>{{localize "PERSISTENT_ZONES.UI.Fields.LinkedWalls"}}</label>
            <input type="checkbox" name="linkedWallsEnabled" data-rerender="true" {{#if state.linkedWallsEnabled}}checked{{/if}}>
          </div>

          {{#if state.linkedWallsEnabled}}
            <div class="form-group">
              <label>{{localize "PERSISTENT_ZONES.UI.Fields.LinkedWallsPreset"}}</label>
              <select name="linkedWallsPreset">
                {{#each linksTerrainContext.linkedWallsPresetOptions as |option|}}
                  <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                {{/each}}
              </select>
            </div>

            {{#if linksTerrainContext.wallHeightSupported}}
              <div class="form-group">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.LinkedWallHeight"}}</label>
                <input type="number" name="linkedWallHeight" value="{{state.linkedWallHeight}}" min="0" step="any">
              </div>
            {{else}}
              <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.Fields.LinkedWallHeight"}}:</strong> {{linksTerrainContext.wallHeightUnavailableMessage}}</p>
            {{/if}}
          {{/if}}

          <div class="form-group">
            <label>{{localize "PERSISTENT_ZONES.UI.Fields.LinkedLight"}}</label>
            <input type="checkbox" name="linkedLightEnabled" data-rerender="true" {{#if state.linkedLightEnabled}}checked{{/if}}>
          </div>

          {{#if state.linkedLightEnabled}}
            <div class="form-group">
              <label>{{localize "PERSISTENT_ZONES.UI.Fields.LinkedLightPreset"}}</label>
              <select name="linkedLightPreset">
                {{#each linksTerrainContext.linkedLightPresetOptions as |option|}}
                  <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                {{/each}}
              </select>
            </div>

            <div class="persistent-zones-item-config__metric-grid">
              <div class="form-group form-group--stacked form-group--compact">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.LinkedLightBright"}}</label>
                <input type="number" name="linkedLightBright" value="{{state.linkedLightBright}}" min="0" step="any">
              </div>

              <div class="form-group form-group--stacked form-group--compact">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.LinkedLightDim"}}</label>
                <input type="number" name="linkedLightDim" value="{{state.linkedLightDim}}" min="0" step="any">
              </div>
            </div>

            <p class="hint">{{localize "PERSISTENT_ZONES.UI.Help.LinkedLightRangesHint"}}</p>
          {{/if}}
        </div>
      </details>
    </section>

    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--validation">
      <details class="persistent-zones-item-config__section-toggle" open>
        <summary class="persistent-zones-item-config__section-summary">
          <span class="persistent-zones-item-config__section-title">{{localize "PERSISTENT_ZONES.UI.Sections.Validation"}}</span>
          <span class="persistent-zones-item-config__section-meta">
            {{#if preview.isValid}}
              {{localize "PERSISTENT_ZONES.UI.Validation.Valid"}}
            {{else}}
              {{localize "PERSISTENT_ZONES.UI.Validation.Invalid"}}
            {{/if}}
          </span>
        </summary>

        <div class="persistent-zones-item-config__section-body">
          <div class="persistent-zones-item-config__validation-header">
            <span class="persistent-zones-item-config__pill {{#if preview.isValid}}is-valid{{else}}is-invalid{{/if}}">
              {{#if preview.isValid}}
                {{localize "PERSISTENT_ZONES.UI.Validation.Valid"}}
              {{else}}
                {{localize "PERSISTENT_ZONES.UI.Validation.Invalid"}}
              {{/if}}
            </span>
            {{#if preview.warnings.length}}
              <span class="persistent-zones-item-config__pill is-warning">
                {{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}
              </span>
            {{/if}}
          </div>

          {{#if preview.reasons.length}}
            <ul class="persistent-zones-item-config__reasons">
              {{#each preview.reasons as |reason|}}
                <li>{{reason}}</li>
              {{/each}}
            </ul>
          {{else}}
            <p class="hint">{{localize "PERSISTENT_ZONES.UI.Validation.NoIssues"}}</p>
          {{/if}}

          {{#if preview.warnings.length}}
            <ul class="persistent-zones-item-config__warnings">
              {{#each preview.warnings as |warning|}}
                <li>{{warning}}</li>
              {{/each}}
            </ul>
          {{/if}}
        </div>
      </details>
    </section>

    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--preview">
      <details class="persistent-zones-item-config__section-toggle">
        <summary class="persistent-zones-item-config__section-summary">
          <span class="persistent-zones-item-config__section-title">{{localize "PERSISTENT_ZONES.UI.Sections.AdvancedDebug"}}</span>
          <span class="persistent-zones-item-config__section-meta">{{localize "PERSISTENT_ZONES.UI.Sections.StructuredDebug"}}</span>
        </summary>

        <div class="persistent-zones-item-config__section-body">
          <h3>{{localize "PERSISTENT_ZONES.UI.Sections.StructuredDebug"}}</h3>
          <div class="persistent-zones-item-config__meta">
            {{#each preview.debugInspector.overviewRows as |row|}}
              <div>
                <strong>{{row.label}}:</strong>
                <span>{{row.value}}</span>
              </div>
            {{/each}}
          </div>

          {{#if preview.debugInspector.partSummaries.length}}
            <div class="persistent-zones-item-config__debug-parts">
              {{#each preview.debugInspector.partSummaries as |part|}}
                <fieldset class="persistent-zones-item-config__part-section">
                  <legend>{{part.label}}</legend>

                  <div class="persistent-zones-item-config__meta">
                    <div>
                      <strong>{{localize "PERSISTENT_ZONES.UI.Fields.PartId"}}:</strong>
                      <span>{{part.id}}</span>
                    </div>
                    <div>
                      <strong>{{localize "PERSISTENT_ZONES.UI.Fields.GeometryType"}}:</strong>
                      <span>{{part.geometryTypeLabel}}</span>
                    </div>
                  </div>

                  <ul class="persistent-zones-item-config__debug-list">
                    {{#each part.triggerSummaries as |trigger|}}
                      <li>
                        <strong>{{trigger.label}}:</strong>
                        <span>{{trigger.summaryText}}</span>
                      </li>
                    {{/each}}
                  </ul>
                </fieldset>
              {{/each}}
            </div>
          {{/if}}

          {{#if preview.debugInspector.warnings.length}}
            <h3>{{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}</h3>
            <ul class="persistent-zones-item-config__warnings">
              {{#each preview.debugInspector.warnings as |warning|}}
                <li>{{warning}}</li>
              {{/each}}
            </ul>
          {{/if}}

          {{#if preview.debugInspector.reasons.length}}
            <h3>{{localize "PERSISTENT_ZONES.UI.Sections.Validation"}}</h3>
            <ul class="persistent-zones-item-config__reasons">
              {{#each preview.debugInspector.reasons as |reason|}}
                <li>{{reason}}</li>
              {{/each}}
            </ul>
          {{/if}}

          <details class="persistent-zones-item-config__json-details">
            <summary>{{localize "PERSISTENT_ZONES.UI.Sections.RawDefinition"}}</summary>
            <textarea readonly>{{preview.rawDefinitionJson}}</textarea>
          </details>

          <details class="persistent-zones-item-config__json-details">
            <summary>{{localize "PERSISTENT_ZONES.UI.Sections.NormalizedDefinition"}}</summary>
            <textarea readonly>{{preview.normalizedDefinitionJson}}</textarea>
          </details>
        </div>
      </details>
    </section>

    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--actions">
      <button type="button" class="button" data-action="preview">
        <i class="fas fa-search"></i>
        <span>{{localize "PERSISTENT_ZONES.UI.Actions.Preview"}}</span>
      </button>
      <button type="submit" class="button default">
        <i class="fas fa-save"></i>
        <span>{{localize "PERSISTENT_ZONES.UI.Actions.Save"}}</span>
      </button>
      <button type="button" class="button" data-action="clear">
        <i class="fas fa-trash"></i>
        <span>{{localize "PERSISTENT_ZONES.UI.Actions.Clear"}}</span>
      </button>
    </section>
  </div>
</form>
