<form class="persistent-zones-item-config">
  <div class="persistent-zones-item-config__shell">
    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--primary">
      <h2>{{localize "PERSISTENT_ZONES.UI.Sections.Activation"}}</h2>

      <div class="form-group">
        <label>{{localize "PERSISTENT_ZONES.UI.Fields.Enabled"}}</label>
        <input type="checkbox" name="enabled" {{#if state.enabled}}checked{{/if}}>
      </div>

      <div class="form-group form-group--stacked">
        <label>{{localize "PERSISTENT_ZONES.UI.Fields.BaseType"}}</label>
        <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--four">
          {{#each baseTypeOptions as |option|}}
            <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
              <input type="radio" name="baseType" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
              <span>{{option.label}}</span>
            </label>
          {{/each}}
        </div>

        <p class="hint">
          <strong>{{localize "PERSISTENT_ZONES.UI.Fields.EffectiveTemplateType"}}:</strong>
          {{templateTypeContext.effectiveTemplateTypeLabel}}
        </p>
        {{#if selectionContext.compatibleBaseTypeLabels}}
          <p class="hint">
            <strong>{{localize "PERSISTENT_ZONES.UI.Compatibility.CompatibleBaseTypes"}}:</strong>
            {{selectionContext.compatibleBaseTypeLabels}}
          </p>
        {{/if}}
        {{#if selectionContext.baseTypeWarningReason}}
          <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}:</strong> {{selectionContext.baseTypeWarningReason}}</p>
        {{/if}}
        <div class="persistent-zones-item-config__meta">
          <div>
            <strong>{{localize "PERSISTENT_ZONES.UI.Fields.DetectedTemplateType"}}:</strong>
            <span>
              {{#if templateTypeContext.detectedTemplateTypeLabel}}
                {{templateTypeContext.detectedTemplateTypeLabel}}
              {{else}}
                {{localize "PERSISTENT_ZONES.UI.NoneOption"}}
              {{/if}}
            </span>
          </div>
          <div>
            <strong>{{localize "PERSISTENT_ZONES.UI.Fields.DetectedTemplateSource"}}:</strong>
            <span>{{templateTypeContext.detectedTemplateSourceLabel}}</span>
          </div>
          <div>
            <strong>{{localize "PERSISTENT_ZONES.UI.Fields.EffectiveTemplateType"}}:</strong>
            <span>{{templateTypeContext.effectiveTemplateTypeLabel}}</span>
          </div>
        </div>

        {{#if templateTypeContext.warningReason}}
          <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}:</strong> {{templateTypeContext.warningReason}}</p>
        {{/if}}

      {{#if showWallThickness}}
        <div class="form-group">
          <label>{{localize "PERSISTENT_ZONES.UI.Fields.WallThickness"}}</label>
          <input type="text" name="wallThickness" value="{{state.wallThickness}}" inputmode="decimal" placeholder="1.0">
        </div>
      {{/if}}

      {{#if showSideThickness}}
        <div class="form-group">
          <label>{{localize "PERSISTENT_ZONES.UI.Fields.SideThickness"}}</label>
          <input type="text" name="sideThickness" value="{{state.sideThickness}}" inputmode="decimal" placeholder="3.0">
        </div>
      {{/if}}
      </div>
    </section>

    {{#if showVariantSelect}}
      <section class="persistent-zones-item-config__card">
        <h2>{{localize "PERSISTENT_ZONES.UI.Fields.SelectedVariant"}}</h2>

        <div class="persistent-zones-item-config__choice-group">
          {{#each variantOptions as |option|}}
            <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
              <input type="radio" name="selectedVariant" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
              <span>{{option.label}}</span>
            </label>
          {{/each}}
        </div>

        {{#if selectedVariantLabel}}
          <p class="hint">
            <strong>{{localize "PERSISTENT_ZONES.UI.Fields.SelectedVariant"}}:</strong>
            {{selectedVariantLabel}}
          </p>
        {{/if}}
        {{#if selectionContext.compatibleVariantLabels}}
          <p class="hint">
            <strong>{{localize "PERSISTENT_ZONES.UI.Compatibility.CompatibleVariants"}}:</strong>
            {{selectionContext.compatibleVariantLabels}}
          </p>
        {{/if}}
        {{#if selectionContext.variantWarningReason}}
          <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}:</strong> {{selectionContext.variantWarningReason}}</p>
        {{/if}}
      </section>
    {{/if}}

    {{#if showGlobalTriggers}}
      <section class="persistent-zones-item-config__card">
        <h2>{{localize "PERSISTENT_ZONES.UI.Sections.Behaviors"}}</h2>

        {{#each globalTriggerSections as |triggerSection|}}
          <fieldset class="persistent-zones-item-config__part-section">
            <legend>{{triggerSection.label}}</legend>

            <div class="form-group form-group--stacked">
              <label>{{localize "PERSISTENT_ZONES.UI.Fields.TriggerMode"}}</label>
              <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--three">
                {{#each triggerSection.modeOptions as |option|}}
                  <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                    <input type="radio" name="{{triggerSection.modeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                    <span>{{option.label}}</span>
                  </label>
                {{/each}}
              </div>
            </div>

            {{#if triggerSection.showSimpleFields}}
              <div class="form-group">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.DamageFormula"}}</label>
                <input type="text" name="{{triggerSection.damageFormulaFieldName}}" value="{{triggerSection.state.damageFormula}}" placeholder="2d6">
              </div>

              <div class="form-group">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.DamageType"}}</label>
                <select name="{{triggerSection.damageTypeFieldName}}">
                  {{#each triggerSection.damageTypeOptions as |option|}}
                    <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                  {{/each}}
                </select>
              </div>

              <div class="form-group">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveAbility"}}</label>
                <select name="{{triggerSection.saveAbilityFieldName}}" data-rerender="true">
                  {{#each triggerSection.abilityOptions as |option|}}
                    <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                  {{/each}}
                </select>
              </div>

              {{#if triggerSection.showSaveDcMode}}
                <div class="form-group form-group--stacked">
                  <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveDcMode"}}</label>
                  <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--two">
                    {{#each triggerSection.saveDcModeOptions as |option|}}
                      <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                        <input type="radio" name="{{triggerSection.saveDcModeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                        <span>{{option.label}}</span>
                      </label>
                    {{/each}}
                  </div>
                </div>
              {{/if}}

              {{#if triggerSection.showManualSaveDc}}
                <div class="form-group">
                  <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveDc"}}</label>
                  <input type="number" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}" min="1" step="1">
                </div>
              {{else}}
                <input type="hidden" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}">
              {{/if}}
            {{else}}
              <input type="hidden" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}">
            {{/if}}

            {{#if triggerSection.showActivityField}}
              <div class="form-group">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.Activity"}}</label>
                <select name="{{triggerSection.activityFieldName}}">
                  {{#each triggerSection.activityField.options as |option|}}
                    <option value="{{option.value}}" {{#if option.selected}}selected{{/if}} {{#if option.disabled}}disabled{{/if}}>{{option.label}}</option>
                  {{/each}}
                </select>
              </div>

              <p class="hint">{{triggerSection.activityField.helpText}}</p>

              {{#if triggerSection.activityField.noCompatibleActivitiesMessage}}
                <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.ActivityCompatibility.Incompatible"}}:</strong> {{triggerSection.activityField.noCompatibleActivitiesMessage}}</p>
              {{/if}}

              {{#if triggerSection.activityField.selectedActivityMessage}}
                <p class="hint"><strong>{{triggerSection.activityField.selectedActivityStatusLabel}}:</strong> {{triggerSection.activityField.selectedActivityMessage}}</p>
              {{/if}}
            {{/if}}
          </fieldset>
        {{/each}}
      </section>
    {{/if}}

    {{#if showCompositePartSections}}
      {{#each partSections as |part|}}
        <section class="persistent-zones-item-config__card persistent-zones-item-config__card--part">
          <h2>{{part.label}}</h2>

          {{#each part.triggerSections as |triggerSection|}}
            <fieldset class="persistent-zones-item-config__part-section">
              <legend>{{triggerSection.label}}</legend>

              <div class="form-group form-group--stacked">
                <label>{{localize "PERSISTENT_ZONES.UI.Fields.TriggerMode"}}</label>
                <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--three">
                  {{#each triggerSection.modeOptions as |option|}}
                    <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                      <input type="radio" name="{{triggerSection.modeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                      <span>{{option.label}}</span>
                    </label>
                  {{/each}}
                </div>
              </div>

              {{#if triggerSection.showSimpleFields}}
                <div class="form-group">
                  <label>{{localize "PERSISTENT_ZONES.UI.Fields.DamageFormula"}}</label>
                  <input type="text" name="{{triggerSection.damageFormulaFieldName}}" value="{{triggerSection.state.damageFormula}}" placeholder="2d6">
                </div>

                <div class="form-group">
                  <label>{{localize "PERSISTENT_ZONES.UI.Fields.DamageType"}}</label>
                  <select name="{{triggerSection.damageTypeFieldName}}">
                    {{#each triggerSection.damageTypeOptions as |option|}}
                      <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                    {{/each}}
                  </select>
                </div>

                <div class="form-group">
                  <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveAbility"}}</label>
                  <select name="{{triggerSection.saveAbilityFieldName}}" data-rerender="true">
                    {{#each triggerSection.abilityOptions as |option|}}
                      <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                    {{/each}}
                  </select>
                </div>

                {{#if triggerSection.showSaveDcMode}}
                  <div class="form-group form-group--stacked">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveDcMode"}}</label>
                    <div class="persistent-zones-item-config__choice-group persistent-zones-item-config__choice-group--two">
                      {{#each triggerSection.saveDcModeOptions as |option|}}
                        <label class="persistent-zones-item-config__choice {{#if option.selected}}is-selected{{/if}}">
                          <input type="radio" name="{{triggerSection.saveDcModeFieldName}}" value="{{option.value}}" data-rerender="true" {{#if option.selected}}checked{{/if}}>
                          <span>{{option.label}}</span>
                        </label>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}

                {{#if triggerSection.showManualSaveDc}}
                  <div class="form-group">
                    <label>{{localize "PERSISTENT_ZONES.UI.Fields.SaveDc"}}</label>
                    <input type="number" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}" min="1" step="1">
                  </div>
                {{else}}
                  <input type="hidden" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}">
                {{/if}}
              {{else}}
                <input type="hidden" name="{{triggerSection.saveDcFieldName}}" value="{{triggerSection.state.saveDc}}">
              {{/if}}

              {{#if triggerSection.showActivityField}}
                <div class="form-group">
                  <label>{{localize "PERSISTENT_ZONES.UI.Fields.Activity"}}</label>
                  <select name="{{triggerSection.activityFieldName}}">
                    {{#each triggerSection.activityField.options as |option|}}
                      <option value="{{option.value}}" {{#if option.selected}}selected{{/if}} {{#if option.disabled}}disabled{{/if}}>{{option.label}}</option>
                    {{/each}}
                  </select>
                </div>

                <p class="hint">{{triggerSection.activityField.helpText}}</p>

                {{#if triggerSection.activityField.noCompatibleActivitiesMessage}}
                  <p class="hint"><strong>{{localize "PERSISTENT_ZONES.UI.ActivityCompatibility.Incompatible"}}:</strong> {{triggerSection.activityField.noCompatibleActivitiesMessage}}</p>
                {{/if}}

                {{#if triggerSection.activityField.selectedActivityMessage}}
                  <p class="hint"><strong>{{triggerSection.activityField.selectedActivityStatusLabel}}:</strong> {{triggerSection.activityField.selectedActivityMessage}}</p>
                {{/if}}
              {{/if}}
            </fieldset>
          {{/each}}
        </section>
      {{/each}}
    {{/if}}

    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--validation">
      <h2>{{localize "PERSISTENT_ZONES.UI.Sections.Validation"}}</h2>

      <div class="persistent-zones-item-config__validation-header">
        <span class="persistent-zones-item-config__pill {{#if preview.isValid}}is-valid{{else}}is-invalid{{/if}}">
          {{#if preview.isValid}}
            {{localize "PERSISTENT_ZONES.UI.Validation.Valid"}}
          {{else}}
            {{localize "PERSISTENT_ZONES.UI.Validation.Invalid"}}
          {{/if}}
        </span>
        {{#if preview.warnings.length}}
          <span class="persistent-zones-item-config__pill is-warning">
            {{localize "PERSISTENT_ZONES.UI.Validation.Warning"}}
          </span>
        {{/if}}
      </div>

      {{#if preview.reasons.length}}
        <ul class="persistent-zones-item-config__reasons">
          {{#each preview.reasons as |reason|}}
            <li>{{reason}}</li>
          {{/each}}
        </ul>
      {{else}}
        <p class="hint">{{localize "PERSISTENT_ZONES.UI.Validation.NoIssues"}}</p>
      {{/if}}

      {{#if preview.warnings.length}}
        <ul class="persistent-zones-item-config__warnings">
          {{#each preview.warnings as |warning|}}
            <li>{{warning}}</li>
          {{/each}}
        </ul>
      {{/if}}
    </section>

    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--actions">
      <button type="button" class="button" data-action="preview">
        <i class="fas fa-search"></i>
        <span>{{localize "PERSISTENT_ZONES.UI.Actions.Preview"}}</span>
      </button>
      <button type="submit" class="button default">
        <i class="fas fa-save"></i>
        <span>{{localize "PERSISTENT_ZONES.UI.Actions.Save"}}</span>
      </button>
      <button type="button" class="button" data-action="clear">
        <i class="fas fa-trash"></i>
        <span>{{localize "PERSISTENT_ZONES.UI.Actions.Clear"}}</span>
      </button>
    </section>

    <section class="persistent-zones-item-config__card persistent-zones-item-config__card--preview">
      <details>
        <summary>{{localize "PERSISTENT_ZONES.UI.Sections.AdvancedDebug"}}</summary>

        <div class="persistent-zones-item-config__meta">
          <div>
            <strong>{{localize "PERSISTENT_ZONES.UI.Fields.PreviewTemplateType"}}:</strong>
            <span>{{preview.previewTemplateTypeLabel}}</span>
          </div>
          {{#if preview.normalizedDefinition.variantCount}}
            <div>
              <strong>{{localize "PERSISTENT_ZONES.UI.Fields.AvailableVariants"}}:</strong>
              <span>{{preview.normalizedDefinition.availableVariants}}</span>
            </div>
            <div>
              <strong>{{localize "PERSISTENT_ZONES.UI.Fields.SelectedVariant"}}:</strong>
              <span>{{preview.normalizedDefinition.selectedVariantId}}</span>
            </div>
            <div>
              <strong>{{localize "PERSISTENT_ZONES.UI.Fields.DefaultVariant"}}:</strong>
              <span>{{preview.normalizedDefinition.defaultVariantId}}</span>
            </div>
            <div>
              <strong>{{localize "PERSISTENT_ZONES.UI.Fields.VariantResolutionMode"}}:</strong>
              <span>{{preview.variantResolution.resolutionMode}}</span>
            </div>
          {{/if}}
        </div>

        <h3>{{localize "PERSISTENT_ZONES.UI.Sections.RawDefinition"}}</h3>
        <textarea readonly>{{preview.rawDefinitionJson}}</textarea>

        <h3>{{localize "PERSISTENT_ZONES.UI.Sections.NormalizedDefinition"}}</h3>
        <textarea readonly>{{preview.normalizedDefinitionJson}}</textarea>
      </details>
    </section>
  </div>
</form>
